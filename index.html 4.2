        <div class="phase-hdr-icon">${ph.icon}</div>
        <div>
          <div class="phase-hdr-title">${ph.label}</div>
          <div class="phase-hdr-desc">${ph.desc}</div>
        </div>`;
      scroll.appendChild(hdr);
      lastPh = q.ph;
    }
    const block = document.createElement('div');
    block.className = 'q-block locked';
    block.id = 'qblock-' + idx;
    block.innerHTML = buildQHTML(q, idx);
    scroll.appendChild(block);
  });

  // Results section at bottom
  const resWrap = document.createElement('div');
  resWrap.className = 'results-wrap';
  resWrap.id = 'resultsWrap';
  resWrap.innerHTML = buildResultsHTML();
  scroll.appendChild(resWrap);

  unlockUpTo(0);
  updateProgress();
}

function buildQHTML(q, idx) {
  const val = answers[q.id];
  const isAnswered = val !== undefined && val !== null && val !== '';
  let inputHTML = '';
  if (isAnswered) {
    let displayVal = val;
    if (typeof val === 'object' && !Array.isArray(val)) {
        displayVal = q.fields.map(f => `${f.label.split(' ')[0]}: ${val[f.id]||'-'}`).join(' | ');
    } else if (Array.isArray(val)) {
        displayVal = val.join(', ');
    } else {
        displayVal = val + (q.unit ? ' ' + q.unit : '');
    }

    inputHTML = `
      <div class="answer-display">
        <div class="answer-value">✅ ${displayVal}</div>
        <button class="edit-btn" onclick="editQuestion(${idx})">✏️ Editar</button>
      </div>`;
  } else {
    inputHTML = buildWidget(q, idx);
  }
  return `
    <div class="q-num">Q${idx + 1} / ${TOTAL} · FASE ${q.ph + 1}</div>
    <div class="q-label">${q.label}</div>
    ${q.note ? `<div class="q-note">${q.note}</div>` : ''}
    <div id="widget-${idx}">${inputHTML}</div>`;
}

function buildWidget(q, idx) {
  if (q.type === 'choice') {
    const opts = q.opts.map(o =>
      `<button class="choice-opt" onclick="submitChoice(${idx},'${encodeURIComponent(o)}')">${o}</button>`
    ).join('');
    return `<div class="choices-wrap">${opts}</div>`;
  }
  if (q.type === 'multi') {
    const opts = q.opts.map(o =>
      `<button class="choice-opt" id="mopt-${idx}-${encodeURIComponent(o)}" onclick="toggleMulti(${idx},'${encodeURIComponent(o)}')">${o}</button>`
    ).join('');
    return `
      <div class="choices-wrap" id="mgrid-${idx}">${opts}</div>
      <div class="confirm-row">
        <button class="confirm-btn" onclick="submitMulti(${idx})">Confirmar →</button>
      </div>`;
  }
  if (q.type === 'group') {
    const gAns = answers[q.id] || {};
    const fieldsHtml = q.fields.map(f => {
      let input = '';
      if (f.type === 'select') {
        input = `<select id="gf-${q.id}-${f.id}" class="field-inp" style="width:100%;margin-top:4px;padding:8px;">
          <option value="">Seleccione...</option>
          ${f.opts.map(o => `<option value="${o}" ${gAns[f.id]===o?'selected':''}>${o}</option>`).join('')}
        </select>`;
      } else {
        input = `<input type="${f.type}" id="gf-${q.id}-${f.id}" value="${gAns[f.id]||''}" class="field-inp" style="width:100%;margin-top:4px;padding:8px;" placeholder="${f.ph||''}">`;
      }
      return `<div style="margin-bottom:10px;"><div style="font-size:11px;font-weight:700;color:var(--muted);">${f.label}</div>${input}</div>`;
    }).join('');

    return `
      <div style="background:#fafaf8; border:1px solid var(--border); border-radius:8px; padding:12px; margin-bottom:10px; display:grid; grid-template-columns:1fr 1fr; gap:10px;">
        ${fieldsHtml}
      </div>
      <div class="confirm-row">
        <button class="confirm-btn" onclick="submitGroup(${idx})">Confirmar Tabla →</button>
      </div>
    `;
  }
  if (q.type === 'text' || q.type === 'text+gps') {
    const isGps = q.type === 'text+gps';
    return `
      <div class="inp-row">
        <input class="field-inp" type="text" placeholder="${q.ph_txt||''}" id="tinp-${idx}"
          style="max-width:none;flex:1"
          onkeydown="if(event.key==='Enter') submitText(${idx})">
        <button class="confirm-btn" onclick="submitText(${idx})">→</button>
      </div>
      ${isGps ? `
        <div style="display:flex;gap:8px;margin-top:8px">
          <button class="gps-btn" id="gpsbtn-${idx}" style="flex:1;justify-content:center" onclick="captureGPS(${idx})">📍 Auto GPS</button>
          <button class="gps-btn" style="flex:1;justify-content:center;background:#e0f2fe;color:#1d4ed8;border-color:#93c5fd" onclick="openMapPicker(${idx})">🗺️ Satélite Manual</button>
        </div>
        <div class="gps-preview" id="gpsprev-${idx}">📍 <span id="gpscoord-${idx}"></span></div>
      ` : ''}
      ${q.opt ? `<div class="confirm-row" style="margin-top:8px"><button class="skip-btn" onclick="submitTextSkip(${idx})">Omitir</button></div>` : ''}`;
  }
  if (q.type === 'number') {
    return `
      <div class="inp-row">
        <input class="field-inp" type="number" min="${q.min??0}" step="${q.step??1}"
          value="${q.def??''}" placeholder="${q.def??0}" id="ninp-${idx}"
          onkeydown="if(event.key==='Enter') submitNumber(${idx})">
        <span class="inp-unit">${q.unit||''}</span>
        ${q.opt ? `<button class="skip-btn" onclick="submitNumber(${idx},true)">Omitir</button>` : ''}
        <button class="confirm-btn" onclick="submitNumber(${idx})">→</button>
      </div>`;
  }
  return '';
}

function buildResultsHTML() {
  return `
    <div style="font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:9px">Resultados en tiempo real · ISA · APO · QTRA</div>
    <div class="results-top">
      <div class="r-card">
        <div class="r-card-label">ISA TRAQ</div>
        <div class="r-card-val" id="r-isaLevel">—</div>
        <div class="r-card-sub" id="r-isaSub">Esperando datos...</div>
        <div id="r-override" style="display:none;margin-top:5px;font-size:9px;font-weight:700;color:#fbbf24;background:rgba(251,191,36,.15);padding:3px 7px;border-radius:5px">⚡ Override biomecánico</div>
      </div>
      <div class="r-card" style="background:linear-gradient(135deg,#1e3a5f,#0c1e33)">
        <div class="r-card-label">QTRA v5</div>
        <div class="qtra-frac r-card-val" id="r-qtraFrac" style="font-size:18px">1/∞</div>
        <div class="r-card-sub" id="r-alarp">Esperando datos...</div>
      </div>
    </div>
    <div class="r-bio">
      <div class="r-bio-label">Rinntech APO — Biomecánica</div>
      <div class="r-bio-row"><span class="r-bio-key">t_req (mínimo)</span><span class="r-bio-val rv-neu" id="r-treq">—</span></div>
      <div class="r-bio-row"><span class="r-bio-key">t_actual (medido)</span><span class="r-bio-val rv-neu" id="r-tact">—</span></div>
      <div class="r-bio-row"><span class="r-bio-key">Margen estructural</span><span class="r-bio-val rv-neu" id="r-margin">—</span></div>
      <div class="bio-bar-wrap"><div class="bio-bar" id="r-bioBar" style="width:0%;background:var(--g500)"></div></div>
      <div class="crit-alert" id="r-crit">⚠️ CUELLO DE BOTELLA CRÍTICO — Riesgo de colapso estructural</div>
    </div>
    <div class="recs-wrap">
      <div class="recs-title">💡 Recomendaciones</div>
      <div id="r-recs"><div class="rec-item"><div class="rec-dot" style="background:#ccc"></div>Complete el cuestionario para obtener recomendaciones.</div></div>
    </div>
    <button class="save-btn" id="saveBtn" disabled onclick="saveAssessment()">
      💾 Guardar Evaluación en la Nube
    </button>`;
}

// ─── MULTI TOGGLE ─────────────────────────────────────────
function toggleMulti(idx, encVal) {
  const val = decodeURIComponent(encVal);
  const q = QS[idx];
  if (!_multiSel[idx]) _multiSel[idx] = new Set();
  const sel = _multiSel[idx];
  const btn = document.getElementById('mopt-' + idx + '-' + encVal);
  if (val === q.none) {
    sel.clear(); sel.add(val);
    document.querySelectorAll('#mgrid-' + idx + ' .choice-opt').forEach(b => b.classList.remove('multi-sel'));
    btn.classList.add('multi-sel');
  } else {
    const noneEnc = encodeURIComponent(q.none);
    const noneBtn = document.getElementById('mopt-' + idx + '-' + noneEnc);
    if (noneBtn) noneBtn.classList.remove('multi-sel');
    sel.delete(q.none);
    if (sel.has(val)) { sel.delete(val); btn.classList.remove('multi-sel'); }
    else { sel.add(val); btn.classList.add('multi-sel'); }
  }
}

// ─── SUBMIT FUNCTIONS ─────────────────────────────────────
function submitChoice(idx, encVal) {
  answers[QS[idx].id] = decodeURIComponent(encVal);
  afterSubmit(idx);
}
function submitMulti(idx) {
  const q = QS[idx];
  const sel = _multiSel[idx];
  answers[q.id] = (sel && sel.size > 0) ? [...sel] : [q.none];
  delete _multiSel[idx];
  afterSubmit(idx);
}
function submitGroup(idx) {
  const q = QS[idx];
  let ans = {};
  q.fields.forEach(f => {
    const el = document.getElementById(`gf-${q.id}-${f.id}`);
    if(el) ans[f.id] = el.value;
  });
  answers[q.id] = ans;
  afterSubmit(idx);
}
function submitText(idx) {
  const inp = document.getElementById('tinp-' + idx);
  const val = inp ? inp.value.trim() : '';
  if (!val) return;
  answers[QS[idx].id] = val;
  afterSubmit(idx);
}
function submitTextSkip(idx) {
  answers[QS[idx].id] = '—';
  afterSubmit(idx);
}
function submitNumber(idx, skip=false) {
  const q = QS[idx];
  const inp = document.getElementById('ninp-' + idx);
  const val = skip ? (q.def ?? 0) : (parseFloat(inp?.value) ?? 0) || 0;
  answers[q.id] = val;
  afterSubmit(idx);
}

function afterSubmit(idx) {
  const block = document.getElementById('qblock-' + idx);
  block.className = 'q-block answered';
  block.innerHTML = buildQHTML(QS[idx], idx);
  const next = idx + 1;
  if (next < TOTAL) {
    unlockUpTo(next);
    scrollToBlock(next);
  } else {
    assessmentDone = true;
    const sb = document.getElementById('saveBtn');
    if (sb) sb.disabled = false;
    showNotif('✅ Evaluación completa');
    setTimeout(() => showCompleteScreen(), 600);
  }
  updateProgress();
  computeAll();
}

function editQuestion(idx) {
  delete answers[QS[idx].id];
  for (let i = idx + 1; i < TOTAL; i++) {
    delete answers[QS[i].id];
    const b = document.getElementById('qblock-' + i);
    if (b) b.className = 'q-block locked';
  }
  assessmentDone = false;
  const sb = document.getElementById('saveBtn');
  if (sb) sb.disabled = true;
  const block = document.getElementById('qblock-' + idx);
  block.className = 'q-block current';
  block.innerHTML = buildQHTML(QS[idx], idx);
  scrollToBlock(idx);
  updateProgress();
  computeAll();
}

function unlockUpTo(idx) {
  for (let i = 0; i < TOTAL; i++) {
    const b = document.getElementById('qblock-' + i);
    if (!b) continue;
    if (i < idx && answers[QS[i].id] !== undefined) {
      b.className = 'q-block answered';
      b.innerHTML = buildQHTML(QS[i], i);
    } else if (i === idx) {
      b.className = 'q-block current';
      b.innerHTML = buildQHTML(QS[i], i);
    } else {
      b.className = 'q-block locked';
    }
  }
}

function scrollToBlock(idx) {
  setTimeout(() => {
    const b = document.getElementById('qblock-' + idx);
    if (b) b.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }, 80);
}

// ─── GPS & MAP PICKER ─────────────────────────────────────
function captureGPS(idx) {
  const btn = document.getElementById('gpsbtn-' + idx);
  if (!navigator.geolocation) { showNotif('GPS no disponible'); return; }
  if (btn) { btn.textContent = '⏳ Localizando...'; btn.style.opacity = '.7'; }
  navigator.geolocation.getCurrentPosition(
    pos => {
      gpsCoords = { lat: pos.coords.latitude, lng: pos.coords.longitude, acc: pos.coords.accuracy };
      if (btn) { btn.textContent = '📍 Auto GPS ✓'; btn.className = 'gps-btn captured'; btn.style.opacity = '1'; }
      const prev = document.getElementById('gpsprev-' + idx);
      const coord = document.getElementById('gpscoord-' + idx);
      if (prev && coord) {
        coord.innerHTML = `${gpsCoords.lat.toFixed(5)}, ${gpsCoords.lng.toFixed(5)} (±${Math.round(gpsCoords.acc)}m)
          <a href="https://maps.google.com/?q=${gpsCoords.lat},${gpsCoords.lng}" target="_blank" style="color:var(--b700);font-weight:700;font-size:10px;margin-left:6px">Ver mapa</a>`;
        prev.classList.add('show');
      }
      showNotif('📍 GPS capturado');
    },
    err => {
      if (btn) { btn.textContent = '❌ Error GPS'; btn.style.opacity = '1'; }
      showNotif('Error GPS: ' + err.message);
    },
    { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
  );
}
window.captureGPS = captureGPS;

function openMapPicker(idx) {
  activeGpsIdx = idx;
  document.getElementById('mapPickerModal').classList.add('open');
  
  if (!pickerMapInstance) {
    pickerMapInstance = L.map('pickerMap', { center: [-33.45, -70.65], zoom: 16 });
    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
      attribution: 'Tiles &copy; Esri', maxZoom: 19
    }).addTo(pickerMapInstance);
  }
  
  setTimeout(() => {
    pickerMapInstance.invalidateSize();
    if (gpsCoords) {
      pickerMapInstance.setView([gpsCoords.lat, gpsCoords.lng], 18);
    } else if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(pos => {
        pickerMapInstance.setView([pos.coords.latitude, pos.coords.longitude], 18);
      }, err => console.log(err), { enableHighAccuracy: true });
    }
  }, 250);
}
window.openMapPicker = openMapPicker;

function closeMapPicker() {
  document.getElementById('mapPickerModal').classList.remove('open');
}
window.closeMapPicker = closeMapPicker;

function confirmMapPicker() {
  const center = pickerMapInstance.getCenter();
  gpsCoords = { lat: center.lat, lng: center.lng, acc: 0 }; 
  
  const prev = document.getElementById('gpsprev-' + activeGpsIdx);
  const coord = document.getElementById('gpscoord-' + activeGpsIdx);
  if (prev && coord) {
    coord.innerHTML = `${gpsCoords.lat.toFixed(5)}, ${gpsCoords.lng.toFixed(5)} (Manual)
      <a href="https://maps.google.com/?q=${gpsCoords.lat},${gpsCoords.lng}" target="_blank" style="color:var(--b700);font-weight:700;font-size:10px;margin-left:6px">Ver mapa</a>`;
    prev.classList.add('show');
  }
  showNotif('📍 Ubicación manual guardada');
  closeMapPicker();
}
window.confirmMapPicker = confirmMapPicker;

// ─── PROGRESS ─────────────────────────────────────────────
function updateProgress() {
  const answered = Object.keys(answers).length;
  const pct = Math.round((answered / TOTAL) * 100);
  const fill = document.getElementById('progFill');
  if (fill) fill.style.width = pct + '%';
  const cnt = document.getElementById('progCount');
  if (cnt) cnt.textContent = answered + ' / ' + TOTAL;
  const lastAns = QS.findIndex(q => answers[q.id] === undefined);
  const curQ = Math.max(0, lastAns < 0 ? TOTAL - 1 : lastAns);
  const phase = QS[Math.min(curQ, TOTAL - 1)].ph;
  const lbl = document.getElementById('progLabel');
  if (lbl) lbl.textContent = PHASES[phase].label;
  for (let i = 0; i < 8; i++) {
    const d = document.getElementById('phd' + i);
    if (d) d.className = 'pdot' + (i < phase ? ' done' : i === phase ? ' active' : '');
  }
}

// ─── ALGORITHMS ───────────────────────────────────────────
function get(id) { return answers[id]; }

function calcBio() {
  const H  = parseFloat(get('H'));
  const C  = parseFloat(get('C'));
  const Hi = 130;
  const Di = parseFloat(get('Di'));
  const Hd = parseFloat(get('Hd'));
  const Dd = parseFloat(get('Dd'));
  const tAct = parseFloat(get('tActual'));
  const topo = get('topologia') || '';

  if ([H,C,Di,Hd,Dd].some(isNaN) || H<=0 || Di<=0 || Dd<=0) return { valid:false, isUnsafe:false };
  if (Hd >= Hi || Hi >= H) return { valid:false, isUnsafe:false };

  const Hf = (H + C) / 2;
  if (Hf <= Hi || Hf <= Hd) return { valid:false, isUnsafe:false };

  const ratio = (Hf - Hd) / (Hf - Hi);
  let inner = Math.pow(Dd, 4) - Math.pow(Di, 3) * Dd * ratio;
  if (inner < 0) inner = 0;
  let t_req = 0.5 * (Dd - Math.pow(inner, 0.25));

  if (topo.includes('exterior') || topo.includes('Exterior')) t_req = t_req / 0.70;
  else if (topo.includes('Apertura') || topo.includes('apertura')) t_req = t_req / 0.50;

  t_req = Math.max(0, t_req);
  const margin = (!isNaN(tAct) && tAct > 0 && t_req > 0) ? (tAct / t_req) * 100 : null;
  const isUnsafe = margin !== null && margin < 100;
  return { valid:true, isUnsafe, margin, t_req, Hf, ratio, tAct: isNaN(tAct) ? 0 : tAct };
}

function calcISA(isUnsafe, margin) {
  // 1. Obtener qué parte tiene mayor probabilidad de fallar (del Q6)
  const parte = get('parteFallo') || '';
  
  // 2. Extraer el impacto correspondiente a esa parte elegida
  let impactoStr = 'muy bajo';
  if (parte.includes('Rama')) impactoStr = get('copa_prob_impacto') || 'muy bajo';
  else if (parte.includes('Tronco')) impactoStr = get('tronco_prob_impacto') || 'muy bajo';
  else if (parte.includes('Raíces')) impactoStr = get('raices_prob_impacto') || 'muy bajo';
  else {
    // Si es "Árbol completo", buscamos el peor caso entre las 3 dianas
    const impacts = [get('copa_prob_impacto'), get('tronco_prob_impacto'), get('raices_prob_impacto')].map(i => (i||'').toLowerCase());
    if (impacts.includes('alto')) impactoStr = 'alto';
    else if (impacts.includes('medio')) impactoStr = 'medio';
    else if (impacts.includes('bajo')) impactoStr = 'bajo';
  }

  impactoStr = impactoStr.toLowerCase();
  const impactoKey = impactoStr.includes('alto') ? 'alto'
    : impactoStr.includes('medio') ? 'medio'
    : impactoStr.includes('muy') ? 'muy_bajo'
    : 'bajo';

  // 3. Probabilidad de Fallo general elegida
  const pf = (get('probFallo') || '').toLowerCase();
  let probFallo = pf.includes('inminente') ? 'inminente'
    : (pf.includes('probable') && !pf.includes('im')) ? 'probable'
    : pf.includes('posible') ? 'posible'
    : 'improbable';

  let override = false;
  if (isUnsafe) {
    override = true;
    probFallo = (margin !== null && margin < 50) ? 'inminente' : 'probable';
  }

  // MATRIZ 1: Probabilidad de Fallo e Impacto
  const m1 = {
    inminente:  {muy_bajo:'improbable', bajo:'algo_probable', medio:'probable',      alto:'muy_probable'},
    probable:   {muy_bajo:'improbable', bajo:'improbable',    medio:'algo_probable', alto:'probable'},
    posible:    {muy_bajo:'improbable', bajo:'improbable',    medio:'improbable',    alto:'algo_probable'},
    improbable: {muy_bajo:'improbable', bajo:'improbable',    medio:'improbable',    alto:'improbable'}
  };
  const probComb = m1[probFallo]?.[impactoKey] || 'improbable';

  // 4. Consecuencias
  const cs = (get('consec') || '').toLowerCase();
  const cons = cs.includes('sever') ? 'severo'
    : cs.includes('signif') ? 'significativa'
    : cs.includes('menor') ? 'menor' : 'insignificante';

  // MATRIZ 2: Categorización del Riesgo
  const m2 = {
    muy_probable:  {insignificante:'bajo', menor:'moderado', significativa:'alto',     severo:'extremo'},
    probable:      {insignificante:'bajo', menor:'moderado', significativa:'alto',     severo:'alto'},
    algo_probable: {insignificante:'bajo', menor:'bajo',     significativa:'moderado', severo:'moderado'},
    improbable:    {insignificante:'bajo', menor:'bajo',     significativa:'bajo',     severo:'bajo'}
  };
  
  return { level: m2[probComb]?.[cons] || 'bajo', probComb, override };
}

function calcQTRA(isUnsafe, margin) {
  const peat = parseFloat(get('peatones')) || 0;
  const veh  = parseFloat(get('vehiculos')) || 0;
  const prop = parseFloat(get('valorProp')) || 0;
  const VOSL = 2600000;

  const tP  = (peat * 5) / 86400;
  const tV  = (veh * 1.6 * 0.1 * 0.36) / 86400;
  const tPr = prop / VOSL;
  const target = Math.min(1, Math.max(tP, tV, tPr, 0));

  const ds = get('diaFallo') || '';
  const size = ds.includes('260')||ds.includes('>') ? 0.5
    : ds.includes('110') ? 0.027
    : ds.includes('25') ? 0.002 : 0;

  let pof;
  if (isUnsafe) {
    pof = (margin !== null && margin < 50) ? 0.5 : 0.1;
  } else {
    const ps = (get('probFallo')||'').toLowerCase();
    pof = ps.includes('inminente') ? 0.1
      : (ps.includes('probable')&&!ps.includes('im')) ? 0.00316
      : ps.includes('posible') ? 0.0003 : 0.00001;
  }

  const roH = target * size * pof;
  if (roH <= 0 || size === 0)
    return { str:'1/∞', denom:Infinity, status:'AMPLIAMENTE ACEPTABLE', cls:'rv-ok', target, size, pof };
  const denom = Math.round(1 / roH);
  const status = denom<=1000 ? 'INACEPTABLE' : denom<=1000000 ? 'TOLERABLE (ALARP)' : 'AMPLIAMENTE ACEPTABLE';
  const cls = denom<=1000 ? 'rv-bad' : denom<=1000000 ? 'rv-warn' : 'rv-ok';
  return { str:'1/'+denom.toLocaleString('es-ES'), denom, status, cls, target, size, pof };
}

function computeAll() {
  const bio  = calcBio();
  const isa  = calcISA(bio.isUnsafe, bio.margin);
  const qtra = calcQTRA(bio.isUnsafe, bio.margin);
  renderResults(bio, isa, qtra);
}

function renderResults(bio, isa, qtra) {
  const lm = {bajo:'BAJO',moderado:'MODERADO',alto:'ALTO',extremo:'EXTREMO'};
  const pl = {improbable:'Improbable',algo_probable:'Algo Probable',probable:'Probable',muy_probable:'Muy Probable'};
  const lc = {bajo:'#4ade80',moderado:'#fbbf24',alto:'#fb923c',extremo:'#f87171'};

  const isaEl = document.getElementById('r-isaLevel');
  if (isaEl) {
    isaEl.textContent = lm[isa.level] || '—';
    isaEl.style.color = lc[isa.level] || '#fff';
    const sub = document.getElementById('r-isaSub');
    if (sub) sub.textContent = pl[isa.probComb] || '—';
    const ov = document.getElementById('r-override');
    if (ov) ov.style.display = isa.override ? 'block' : 'none';
  }

  const qEl = document.getElementById('r-qtraFrac');
  if (qEl) {
    qEl.textContent = qtra.str;
    qEl.className = 'qtra-frac r-card-val ' + qtra.cls;
    const alarp = document.getElementById('r-alarp');
    if (alarp) alarp.textContent = qtra.status;
  }

  if (bio.valid) {
    const treqEl = document.getElementById('r-treq');
    if (treqEl) { treqEl.textContent = bio.t_req.toFixed(2) + ' cm'; treqEl.className = 'r-bio-val rv-warn'; }
    const tactEl = document.getElementById('r-tact');
    if (tactEl) {
      tactEl.textContent = bio.tAct > 0 ? bio.tAct.toFixed(2) + ' cm' : '—';
      if (bio.margin !== null) tactEl.className = 'r-bio-val ' + (bio.isUnsafe ? 'rv-bad' : 'rv-ok');
    }
    const mEl = document.getElementById('r-margin');
    if (mEl && bio.margin !== null) {
      mEl.textContent = bio.margin.toFixed(1) + '%';
      mEl.className = 'r-bio-val ' + (bio.margin >= 130 ? 'rv-ok' : bio.margin >= 100 ? 'rv-warn' : 'rv-bad');
    }
    const barEl = document.getElementById('r-bioBar');
    if (barEl && bio.margin !== null) {
      barEl.style.width = Math.min(100, bio.margin / 2) + '%';
      barEl.style.background = bio.margin >= 130 ? 'linear-gradient(90deg,#22c55e,#4ade80)'
        : bio.margin >= 100 ? 'linear-gradient(90deg,#f59e0b,#fbbf24)'
        : 'linear-gradient(90deg,#dc2626,#f87171)';
    }
    const crit = document.getElementById('r-crit');
    if (crit) crit.className = 'crit-alert' + (bio.isUnsafe ? ' on' : '');
  }

  const recs = buildRecs(isa, bio, qtra);
  const recList = document.getElementById('r-recs');
  if (recList) recList.innerHTML = recs.map(r =>
    `<div class="rec-item"><div class="rec-dot" style="background:${r.c}"></div><span>${r.t}</span></div>`
  ).join('');

  const saveBtn = document.getElementById('saveBtn');
  if (saveBtn && !assessmentDone) saveBtn.disabled = Object.keys(answers).length < 10;
}

function buildRecs(isa, bio, qtra) {
  const recs = [];
  if (isa.level==='extremo') recs.push({c:'#f87171',t:'⛔ EXTREMO: Restricción inmediata de acceso y evaluación de emergencia urgente.'});
  else if (isa.level==='alto') recs.push({c:'#fb923c',t:'⚠️ ALTO: Intervención programada en < 3 meses. Señalización preventiva.'});
  else if (isa.level==='moderado') recs.push({c:'#fbbf24',t:'🟡 MODERADO: Monitoreo regular. Plan de manejo a 6–12 meses.'});
  else recs.push({c:'#4ade80',t:'✅ BAJO: Inspección rutinaria en el intervalo habitual.'});
  if (bio.isUnsafe) recs.push({c:'#f87171',t:`⚡ Rinntech crítico: t_req=${bio.t_req?.toFixed(2)} cm > t_actual. Inspección urgente.`});
  const dr = get('defRaices');
  if (dr && (Array.isArray(dr)?dr:[dr]).some(v=>v.includes('Levantamiento')))
    recs.push({c:'#fb923c',t:'🌱 Levantamiento del plato radicular: evaluar riesgo de volcado.'});
  const sc = get('sueloCond');
  if (sc && (Array.isArray(sc)?sc:[sc]).some(v=>v.includes('Raíces')))
    recs.push({c:'#fbbf24',t:'Raíces cortadas / zanjas: evaluar estabilidad radicular.'});
  if (qtra.denom <= 1000) recs.push({c:'#f87171',t:'QTRA INACEPTABLE: intervención económicamente justificada.'});
  else if (qtra.denom <= 1000000) recs.push({c:'#fbbf24',t:'QTRA ALARP: comparar costo de intervención con riesgo de daño.'});
  return recs;
}

