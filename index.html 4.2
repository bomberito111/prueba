<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Bosques Urbanos v4.2 · Evaluación de Riesgo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;700&family=Fraunces:opsz,wght@9..144,700;9..144,900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
/* ── RESET ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{font-size:15px;height:100%}
body{font-family:'IBM Plex Sans',system-ui,sans-serif;background:#f4f1eb;color:#1a1a1a;height:100%;display:flex;flex-direction:column;overflow:hidden}
/* ── CSS VARS ── */
:root{
  --g900:#0f3320;--g800:#166534;--g700:#15803d;--g500:#22c55e;--g100:#dcfce7;--g50:#f0fdf4;
  --a900:#78350f;--a700:#b45309;--a400:#f59e0b;--a100:#fef3c7;
  --o700:#c2410c;--o400:#f97316;--o100:#ffedd5;
  --r700:#b91c1c;--r400:#f87171;--r100:#fee2e2;
  --b700:#1d4ed8;--b400:#60a5fa;--b100:#dbeafe;
  --ink:#1a1a1a;--paper:#fafaf8;--border:#d4cfc5;--muted:#6b6560;
  --shadow:0 2px 8px rgba(0,0,0,.10);--shadow-lg:0 8px 32px rgba(0,0,0,.15);
  --radius:12px;--nav-h:60px;
}
/* ── APP SHELL ── */
.app-header{
  background:var(--g900);padding:0 12px;
  display:flex;align-items:center;justify-content:space-between;
  min-height:50px;flex-shrink:0;position:relative;z-index:100;gap:8px;
}
.brand{display:flex;align-items:center;gap:8px;min-width:0;flex:1}
.brand-icon{width:30px;height:30px;background:var(--g700);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.brand-text{min-width:0;overflow:hidden}
.brand-name{font-family:'Fraunces',serif;font-size:17px;font-weight:900;color:#fff;letter-spacing:-.5px;line-height:1;white-space:nowrap}
.brand-sub{font-size:9px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#86efac;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.header-actions{display:flex;align-items:center;gap:6px;flex-shrink:0}
.hdr-btn{padding:6px 12px;border-radius:8px;border:1.5px solid rgba(255,255,255,.25);background:rgba(255,255,255,.1);color:#fff;font-family:'IBM Plex Sans',sans-serif;font-weight:700;font-size:11px;cursor:pointer;letter-spacing:.3px;text-transform:uppercase;transition:all .15s;white-space:nowrap}
.hdr-btn:hover{background:rgba(255,255,255,.2)}
.hdr-btn.primary{background:var(--g700);border-color:var(--g700)}
.conn-dot{width:8px;height:8px;border-radius:50%;background:#22c55e;box-shadow:0 0 0 3px rgba(34,197,94,.2);animation:pulse 2s infinite;flex-shrink:0}
@keyframes pulse{0%,100%{box-shadow:0 0 0 3px rgba(34,197,94,.2)}50%{box-shadow:0 0 0 6px rgba(34,197,94,.05)}}
.conn-dot.off{background:#ef4444;animation:none;box-shadow:none}
/* ── BOTTOM NAV ── */
.bottom-nav{background:#fff;border-top:2px solid var(--border);display:flex;padding:0;height:var(--nav-h);flex-shrink:0;position:relative;z-index:100}
.nav-tab{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;cursor:pointer;border:none;background:none;font-family:'IBM Plex Sans',sans-serif;font-size:10px;font-weight:600;color:var(--muted);letter-spacing:.5px;text-transform:uppercase;transition:color .15s;padding:4px 0;position:relative}
.nav-tab.active{color:var(--g800)}
.nav-tab.active::before{content:'';position:absolute;top:0;left:16px;right:16px;height:3px;background:var(--g800);border-radius:0 0 3px 3px}
.nav-icon{font-size:20px;line-height:1}
/* ── VIEWS ── */
.view{display:none;flex:1;overflow:hidden;flex-direction:column}
.view.active{display:flex}
/* ── FORM PROGRESS ── */
.form-progress{background:#fff;border-bottom:1px solid var(--border);padding:10px 14px;flex-shrink:0}
.prog-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;gap:8px}
.prog-label{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--g800);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.prog-count{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted);flex-shrink:0}
.prog-track{height:5px;background:#e5e0d5;border-radius:3px;overflow:hidden}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--g800),var(--g500));border-radius:3px;transition:width .5s ease}
.phase-dots{display:flex;gap:5px;margin-top:6px}
.pdot{flex:1;height:3px;border-radius:2px;background:#e5e0d5;transition:background .3s}
.pdot.done{background:var(--g700)}
.pdot.active{background:var(--g900)}
/* ── FORM SCROLL ── */
.form-scroll{flex:1;overflow-y:auto;padding:0;display:flex;flex-direction:column}
.form-scroll::-webkit-scrollbar{width:4px}
.form-scroll::-webkit-scrollbar-thumb{background:#ddd;border-radius:2px}
/* ── PHASE HEADER ── */
.phase-hdr{padding:14px 16px 10px;border-bottom:1px solid var(--border);background:#fafaf8;display:flex;align-items:center;gap:10px;position:sticky;top:0;z-index:10}
.phase-hdr-icon{width:36px;height:36px;border-radius:9px;background:var(--g900);color:#fff;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.phase-hdr-title{font-family:'Fraunces',serif;font-size:15px;font-weight:700;color:var(--ink)}
.phase-hdr-desc{font-size:10px;font-weight:600;color:var(--muted);margin-top:1px;text-transform:uppercase;letter-spacing:.5px}
/* ── Q BLOCKS ── */
.q-block{padding:16px;border-bottom:1px solid #f0ebe0;transition:background .2s;position:relative}
.q-block.locked{opacity:.4;pointer-events:none}
.q-block.current{background:#fafbff;border-left:4px solid var(--g800)}
.q-block.answered{background:#fff}
.q-num{font-family:'IBM Plex Mono',monospace;font-size:10px;font-weight:700;color:#aaa;letter-spacing:1px;margin-bottom:5px}
.q-label{font-size:15px;font-weight:700;color:var(--ink);line-height:1.35;margin-bottom:10px}
.q-note{font-size:11px;font-weight:600;color:var(--muted);margin-bottom:10px;background:#f5f1eb;padding:7px 10px;border-radius:7px;border-left:3px solid var(--border);line-height:1.4}
/* ── ANSWER DISPLAY ── */
.answer-display{display:flex;align-items:center;justify-content:space-between;gap:10px}
.answer-value{font-size:14px;font-weight:700;color:var(--ink);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.edit-btn{font-size:11px;font-weight:700;color:var(--b700);background:var(--b100);border:1.5px solid #c8d9ff;border-radius:7px;padding:5px 12px;cursor:pointer;white-space:nowrap;flex-shrink:0}
/* ── INPUT WIDGETS ── */
.choices-wrap{display:flex;flex-wrap:wrap;gap:7px}
.choice-opt{font-size:13px;font-weight:600;padding:9px 15px;border-radius:8px;border:1.5px solid var(--border);background:#fff;color:var(--ink);cursor:pointer;transition:all .15s;line-height:1.2;font-family:'IBM Plex Sans',sans-serif}
.choice-opt:hover{border-color:var(--g700);background:var(--g50)}
.choice-opt.selected{border-color:var(--g900);background:var(--g900);color:#fff}
.choice-opt.multi-sel{border-color:var(--b700);background:var(--b100);color:var(--b700)}
.confirm-row{display:flex;align-items:center;gap:8px;margin-top:10px;flex-wrap:wrap}
.confirm-btn{font-weight:700;font-size:13px;padding:10px 20px;border-radius:8px;border:2px solid var(--g900);background:var(--g900);color:#fff;cursor:pointer;font-family:'IBM Plex Sans',sans-serif;transition:all .15s}
.confirm-btn:hover{background:var(--g800)}
.skip-btn{font-weight:600;font-size:12px;padding:9px 14px;border-radius:8px;border:1.5px solid var(--border);background:#fff;color:var(--muted);cursor:pointer;font-family:'IBM Plex Sans',sans-serif}
.inp-row{display:flex;gap:8px;align-items:center}
.field-inp{flex:1;font-family:'IBM Plex Sans',sans-serif;font-weight:600;font-size:14px;padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;background:#fff;color:var(--ink);outline:none;transition:border-color .15s;max-width:200px;-webkit-appearance:none;appearance:none}
.field-inp:focus{border-color:var(--g700)}
.field-inp::placeholder{color:#bbb;font-weight:400}
.inp-unit{font-size:12px;font-weight:700;color:var(--muted);white-space:nowrap}
.gps-btn{padding:9px 14px;border-radius:8px;border:1.5px solid var(--g700);background:#fff;color:var(--g800);font-family:'IBM Plex Sans',sans-serif;font-weight:700;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:5px;transition:all .15s;white-space:nowrap;flex-shrink:0}
.gps-btn:hover{background:var(--g50)}
.gps-btn.captured{background:var(--g800);color:#fff;border-color:var(--g800)}
.gps-preview{display:none;margin-top:8px;padding:7px 10px;background:var(--g50);border:1px solid var(--g700);border-radius:7px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--g800)}
.gps-preview.show{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
/* ── RESULTS CARD (at bottom of form) ── */
.results-wrap{padding:16px;background:#fff;border-top:2px solid var(--border);margin-top:auto}
.results-top{display:flex;gap:10px;margin-bottom:10px}
.r-card{flex:1;background:linear-gradient(135deg,var(--g900),#0a2214);border-radius:10px;padding:12px;color:#fff;min-width:0}
.r-card-label{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#86efac;margin-bottom:4px}
.r-card-val{font-family:'Fraunces',serif;font-size:22px;font-weight:900;color:#fff;line-height:1}
.r-card-sub{font-size:10px;color:rgba(255,255,255,.6);margin-top:3px;font-weight:500}
.r-bio{background:#fff;border:1.5px solid var(--border);border-radius:10px;padding:12px}
.r-bio-label{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.r-bio-row{display:flex;justify-content:space-between;font-size:12px;padding:3px 0;border-bottom:1px solid #f5f0e8}
.r-bio-row:last-child{border-bottom:none}
.r-bio-key{color:var(--muted);font-weight:600}
.r-bio-val{font-family:'IBM Plex Mono',monospace;font-weight:700}
.rv-ok{color:var(--g700)}.rv-warn{color:var(--a700)}.rv-bad{color:var(--r700)}.rv-neu{color:var(--b700)}
.bio-bar-wrap{height:6px;background:#f0ebe0;border-radius:3px;overflow:hidden;margin:7px 0}
.bio-bar{height:100%;border-radius:3px;transition:width .6s ease}
.crit-alert{display:none;padding:7px 10px;background:var(--r100);border:1px solid var(--r400);border-radius:7px;font-size:11px;font-weight:700;color:var(--r700);text-align:center;margin-top:6px;animation:blink 1.5s infinite}
.crit-alert.on{display:block}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.6}}
.recs-wrap{margin-top:10px}
.recs-title{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--g800);margin-bottom:6px}
.rec-item{display:flex;gap:7px;align-items:flex-start;font-size:11px;font-weight:500;line-height:1.4;padding:4px 0;border-bottom:1px solid #f5f0e8;color:var(--ink)}
.rec-item:last-child{border-bottom:none}
.rec-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:3px}
.save-btn{width:100%;padding:14px;border-radius:10px;border:3px solid var(--g900);background:var(--g900);color:#fff;font-family:'IBM Plex Sans',sans-serif;font-weight:700;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .2s;margin-top:12px}
.save-btn:hover:not(:disabled){background:var(--g800)}
.save-btn:disabled{opacity:.35;cursor:not-allowed}
.save-btn.saved{background:var(--g700);border-color:var(--g700)}
/* ── QTRA display ── */
.qtra-frac{font-family:'IBM Plex Mono',monospace;font-size:20px;font-weight:700;line-height:1}
/* ── MAP VIEW ── */
#leafletMap{width:100%;height:100%}
.map-overlay{position:absolute;top:10px;left:10px;right:10px;z-index:500;background:rgba(255,255,255,.97);border-radius:10px;padding:10px 14px;box-shadow:var(--shadow-lg);border:1px solid var(--border)}
.map-title{font-family:'Fraunces',serif;font-size:14px;font-weight:900;color:var(--g900)}
.map-sub{font-size:10px;color:var(--muted);margin-top:1px}
.map-legend{display:flex;gap:10px;margin-top:7px;flex-wrap:wrap}
.ml-item{display:flex;align-items:center;gap:4px;font-size:10px;font-weight:600}
.ml-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}

/* ── DB VIEW (FILTROS) ── */
.db-header{background:#fff;border-bottom:1px solid var(--border);padding:12px 16px;flex-shrink:0}
.db-header-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;gap:8px}
.db-title{font-family:'Fraunces',serif;font-size:17px;font-weight:900;color:var(--g900)}
.db-count{font-size:11px;color:var(--muted);font-weight:600;white-space:nowrap}
.db-search{width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;font-family:'IBM Plex Sans',sans-serif;font-size:13px;outline:none;transition:border-color .15s}
.db-search:focus{border-color:var(--g700)}
.db-scroll{flex:1;overflow-y:auto;padding:12px 14px;display:flex;flex-direction:column;gap:8px}
.db-empty{text-align:center;padding:60px 20px;color:var(--muted);font-weight:600;font-size:13px}
/* Tree cards */
.tree-card{background:#fff;border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);cursor:pointer;transition:all .15s}
.tree-card:hover{border-color:var(--g700);transform:translateY(-1px);box-shadow:var(--shadow-lg)}
.tc-head{padding:11px 13px 8px;border-bottom:1px solid #f0ebe0}
.tc-id{font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:700;color:var(--b700)}
.tc-species{font-family:'Fraunces',serif;font-size:14px;font-weight:700;color:var(--ink);margin:2px 0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tc-evaluator{font-size:11px;color:var(--muted)}
.tc-body{padding:9px 13px}
.tc-pills{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:7px}
.tc-pill{font-size:9px;font-weight:700;padding:3px 8px;border-radius:10px;border:1.5px solid;letter-spacing:.5px;text-transform:uppercase}
.tp-low{color:var(--g800);border-color:#86efac;background:var(--g100)}
.tp-mod{color:var(--a900);border-color:#fde68a;background:var(--a100)}
.tp-high{color:var(--o700);border-color:#fed7aa;background:var(--o100)}
.tp-ext{color:var(--r700);border-color:#fecaca;background:var(--r100)}
.tc-meta{display:flex;justify-content:space-between;align-items:center;font-size:10px;color:var(--muted)}
.tc-gps{display:flex;align-items:center;gap:4px;font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--g800)}
/* ── DETAIL MODAL ── */
.modal-overlay{position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);display:none;flex-direction:column;animation:fadeIn .2s ease}
.modal-overlay.open{display:flex}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.modal-inner{background:#fff;border-radius:20px 20px 0 0;max-height:90vh;overflow-y:auto;margin-top:auto;animation:slideUp .3s cubic-bezier(.16,1,.3,1)}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-drag{width:40px;height:4px;border-radius:2px;background:#ddd;margin:12px auto 0}
.modal-head{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:10px}
.modal-title{font-family:'Fraunces',serif;font-size:16px;font-weight:900;color:var(--ink);min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.modal-close{width:32px;height:32px;border-radius:50%;background:#f4f1eb;border:none;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.modal-body{padding:14px 18px 32px}
.detail-section{margin-bottom:14px}
.detail-sec-title{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--g800);margin-bottom:7px;padding-bottom:4px;border-bottom:2px solid var(--g100)}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.detail-item{background:#fafaf8;border-radius:7px;padding:7px 9px;border:1px solid var(--border)}
.di-label{font-size:9px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px}
.di-val{font-size:13px;font-weight:600;color:var(--ink);word-break:break-word}
.risk-banner{border-radius:10px;padding:12px 14px;text-align:center;margin:10px 0;border:3px solid}
.rb-low{background:var(--g100);border-color:var(--g700);color:var(--g900)}
.rb-mod{background:var(--a100);border-color:var(--a400);color:var(--a900)}
.rb-high{background:var(--o100);border-color:var(--o400);color:var(--o700)}
.rb-ext{background:var(--r100);border-color:var(--r400);color:var(--r700);animation:blink 1.5s infinite}
.rb-level{font-family:'Fraunces',serif;font-size:26px;font-weight:900}
.rb-label{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-top:2px}
/* ── COMPLETE SCREEN ── */
.complete-screen{position:fixed;inset:0;z-index:500;background:linear-gradient(135deg,var(--g900),#0a2214);display:none;flex-direction:column;overflow-y:auto}
.complete-screen.open{display:flex}
.cs-header{padding:16px 16px 8px;display:flex;justify-content:space-between;align-items:flex-start;gap:10px;flex-wrap:nowrap}
.cs-title{font-family:'Fraunces',serif;font-size:22px;font-weight:900;color:#fff;line-height:1.1;min-width:0}
.cs-sub{font-size:11px;color:#86efac;margin-top:3px;font-weight:600;letter-spacing:1px;text-transform:uppercase}
.cs-close{padding:8px 14px;border:1.5px solid rgba(255,255,255,.25);border-radius:8px;background:rgba(255,255,255,.1);color:#fff;font-weight:700;font-size:11px;cursor:pointer;font-family:'IBM Plex Sans',sans-serif;white-space:nowrap;flex-shrink:0;align-self:center}
.cs-body{padding:12px 16px 40px;flex:1}
.cs-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:12px 14px;margin-bottom:10px}
.cs-card-title{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#86efac;margin-bottom:9px}
.risk-display{text-align:center;padding:16px}
.rd-level{font-family:'Fraunces',serif;font-size:44px;font-weight:900;transition:all .3s}
.rd-low{color:#4ade80}.rd-mod{color:#fbbf24}.rd-high{color:#fb923c}.rd-ext{color:#f87171;animation:blink 1.5s infinite}
.rd-label{font-size:12px;font-weight:600;color:rgba(255,255,255,.7);letter-spacing:2px;text-transform:uppercase;margin-top:3px}
.cs-metrics{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:9px}
.cs-metric{background:rgba(255,255,255,.08);border-radius:8px;padding:9px 11px}
.csm-label{font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:3px}
.csm-val{font-family:'IBM Plex Mono',monospace;font-size:15px;font-weight:700;color:#fff}
.csm-ok{color:#4ade80}.csm-warn{color:#fbbf24}.csm-bad{color:#f87171}
.rinn-verdict{text-align:center;padding:13px;background:rgba(255,255,255,.05);border-radius:10px;margin-top:9px}
.rv-main{font-family:'Fraunces',serif;font-size:18px;font-weight:900;margin-bottom:5px}
.rv-detail{font-size:11px;color:rgba(255,255,255,.7);line-height:1.5}
.cs-recs{margin-top:7px}
.cs-rec-item{display:flex;gap:7px;align-items:flex-start;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.06);font-size:11px;font-weight:500;color:rgba(255,255,255,.85);line-height:1.4}
.cs-rec-item:last-child{border-bottom:none}
/* ── NOTIFICATION ── */
