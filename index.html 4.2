// ─── FIREBASE SAVE ────────────────────────────────────────
async function saveAssessment() {
  if (!window._fbPush) { showNotif('Firebase no disponible'); return; }
  const bio  = calcBio();
  const isa  = calcISA(bio.isUnsafe, bio.margin);
  const qtra = calcQTRA(bio.isUnsafe, bio.margin);
  const doc = {
    timestamp:   Date.now(),
    arbolId:     get('arbolId') || 'Sin ID',
    especie:     get('especie') || 'Desconocida',
    evaluador:   get('evaluador') || '',
    cliente:     get('cliente') || '',
    gps:         gpsCoords || null,
    isaLevel:    isa.level,
    qtraStr:     qtra.str,
    qtraStatus:  qtra.status,
    qtraDenom:   qtra.denom === Infinity ? null : qtra.denom,
    bioMargin:   bio.margin,
    bioCritical: bio.isUnsafe,
    tReq:        bio.valid ? bio.t_req : null,
    tActual:     bio.tAct || null,
    answers
  };
  try {
    await window._fbPush(doc);
    showNotif('💾 Evaluación guardada en Firebase ✅');
    ['saveBtn','csSaveBtn'].forEach(id => {
      const btn = document.getElementById(id);
      if (btn) { btn.textContent = '✅ Guardado correctamente'; btn.className = 'save-btn saved'; btn.disabled = true; }
    });
  } catch (e) {
    showNotif('❌ Error: ' + e.message);
  }
}
window.saveAssessment = saveAssessment;

// ─── MAP ──────────────────────────────────────────────────
function initMap() {
  if (mapInstance) return;
  
  const osm = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap', maxZoom: 19
  });
  const sat = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
    attribution: 'Tiles &copy; Esri', maxZoom: 19
  });

  mapInstance = L.map('leafletMap', { 
    center: [-33.45, -70.65], 
    zoom: 12,
    layers: [sat] // Mapa satelital por defecto
  });
  
  const baseMaps = {
    "Satelital": sat,
    "Mapa Normal": osm
  };
  L.control.layers(baseMaps).addTo(mapInstance);

  refreshMap();
}

function refreshMap() {
  if (!mapInstance) return;
  mapMarkers.forEach(m => mapInstance.removeLayer(m));
  mapMarkers = [];
  const data = window._dbAll;
  if (!data) { document.getElementById('mapSubtitle').textContent = 'Sin datos registrados.'; return; }
  const entries = Object.entries(data);
  const withGps = entries.filter(([,d]) => d.gps);
  document.getElementById('mapSubtitle').textContent = `${entries.length} árbol(es) · ${withGps.length} con GPS`;
  const colors = {bajo:'#15803d',moderado:'#f59e0b',alto:'#f97316',extremo:'#b91c1c'};
  const bounds = [];
  entries.forEach(([key, d]) => {
    if (!d.gps) return;
    const { lat, lng } = d.gps;
    const color = colors[d.isaLevel] || '#6b7280';
    const icon = L.divIcon({
      className:'',
      html:`<div style="width:26px;height:26px;border-radius:50%;background:${color};border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;font-size:11px">🌳</div>`,
      iconSize:[26,26],iconAnchor:[13,13]
    });
    const lvlLabel = {bajo:'BAJO',moderado:'MODERADO',alto:'ALTO',extremo:'EXTREMO'};
    const marker = L.marker([lat,lng],{icon}).addTo(mapInstance);
    const dt = new Date(d.timestamp).toLocaleDateString('es-ES',{day:'2-digit',month:'short',year:'numeric'});
    marker.bindPopup(`
      <div style="min-width:170px;font-family:'IBM Plex Sans',sans-serif;padding:2px">
        <div style="font-family:'IBM Plex Mono',sans-serif;font-size:11px;font-weight:700;color:#1d4ed8">${d.arbolId}</div>
        <div style="font-size:14px;font-weight:900;color:#1a1a1a;margin:2px 0">${d.especie}</div>
        <div style="font-size:10px;color:#666;margin-bottom:6px">Por ${d.evaluador||'—'} · ${dt}</div>
        <div style="display:inline-block;padding:3px 9px;border-radius:10px;font-size:11px;font-weight:700;background:${color}22;color:${color};border:1.5px solid ${color};margin-bottom:7px">Riesgo: ${lvlLabel[d.isaLevel]||'—'}</div>
        <div style="font-size:10px;color:#666">RoH: ${d.qtraStr||'—'}</div>
        <button onclick="showTreeDetail('${key}')" style="display:block;width:100%;margin-top:7px;padding:7px;background:#166534;color:#fff;border:none;border-radius:7px;font-weight:700;font-size:11px;cursor:pointer">Ver Evaluación Completa</button>
      </div>`);
    mapMarkers.push(marker);
    bounds.push([lat, lng]);
  });
  if (bounds.length > 0) {
    try { mapInstance.fitBounds(bounds, {padding:[40,40],maxZoom:16}); } catch(e) {}
  }
}

// ─── DATABASE ─────────────────────────────────────────────
function populateClientList() {
  const sel = document.getElementById('f-cliente');
  if (!sel || !window._dbAll) return;
  const current = sel.value;
  const clients = new Set();
  Object.values(window._dbAll).forEach(d => {
    if (d.cliente) clients.add(d.cliente);
    else if (d.answers && d.answers.cliente) clients.add(d.answers.cliente);
  });
  sel.innerHTML = '<option value="">Todos</option>' + [...clients].sort().map(c => `<option value="${c}">${c}</option>`).join('');
  sel.value = current;
}
window.populateClientList = populateClientList;

function updateFilters() {
  const searchInput = document.getElementById('dbSearch');
  const clientSelect = document.getElementById('f-cliente');
  const dianaSelect = document.getElementById('f-diana');
  const valorSelect = document.getElementById('f-valor');
  
  if (!window._dbAll) return;

  const search = searchInput ? searchInput.value.toLowerCase() : '';
  const client = clientSelect ? clientSelect.value : '';
  const diana = dianaSelect ? dianaSelect.value : '';
  const valMin = valorSelect ? parseFloat(valorSelect.value) : 0;
  
  const entries = Object.entries(window._dbAll).reverse().filter(([k, d]) => {
    const sMatch = !search ||
      (d.arbolId || '').toLowerCase().includes(search) ||
      (d.especie || '').toLowerCase().includes(search) ||
      (d.evaluador || '').toLowerCase().includes(search);
    const cMatch = !client || d.cliente === client || (d.answers && d.answers.cliente === client);
    const dMatch = !diana || (d.answers && d.answers.tasaOcup && d.answers.tasaOcup.startsWith(diana));
    const vMatch = ((d.answers && parseFloat(d.answers.valorProp)) || 0) >= valMin;
    return sMatch && cMatch && dMatch && vMatch;
  });

  renderDBList(entries);
}
window.updateFilters = updateFilters;

function renderDBList(entries) {
  const scroll = document.getElementById('dbScroll');
  const count = document.getElementById('dbCount');
  if (!scroll) return;

  const totalCount = Object.keys(window._dbAll || {}).length;
  if (count) count.textContent = entries.length + ' de ' + totalCount + ' evaluaciones';

  if (!entries.length) {
    scroll.innerHTML = `<div class="db-empty">🔍 Sin resultados</div>`;
    return;
  }
  
  const lvlCls = {bajo:'tp-low',moderado:'tp-mod',alto:'tp-high',extremo:'tp-ext'};
  const lvlLabel = {bajo:'Bajo',moderado:'Moderado',alto:'Alto',extremo:'Extremo'};
  
  scroll.innerHTML = entries.map(([key, d]) => {
    const dt = new Date(d.timestamp).toLocaleDateString('es-ES',{day:'2-digit',month:'short',year:'2-digit',hour:'2-digit',minute:'2-digit'});
    return `
      <div class="tree-card" onclick="showTreeDetail('${key}')">
        <div class="tc-head">
          <div class="tc-id">${d.arbolId}</div>
          <div class="tc-species">${d.especie}</div>
          <div class="tc-evaluator">Por: ${d.evaluador||'—'}${d.cliente?' · '+d.cliente:''}</div>
        </div>
        <div class="tc-body">
          <div class="tc-pills">
            <span class="tc-pill ${lvlCls[d.isaLevel]||'tp-low'}">ISA: ${lvlLabel[d.isaLevel]||'—'}</span>
            <span class="tc-pill" style="color:#555;border-color:#ddd">RoH: ${d.qtraStr||'—'}</span>
            ${d.bioCritical?'<span class="tc-pill tp-ext">⚠️ Cuello Crítico</span>':''}
          </div>
          <div class="tc-meta">
            ${d.gps?`<div class="tc-gps">📍 ${d.gps.lat.toFixed(4)}, ${d.gps.lng.toFixed(4)}</div>`:'<div></div>'}
            <div class="tc-date">${dt}</div>
          </div>
          ${d.bioMargin!=null?`<div style="margin-top:3px;font-size:10px;font-weight:700;color:${d.bioCritical?'var(--r700)':'var(--g800)'}">Margen Rinntech: ${typeof d.bioMargin==='number'?d.bioMargin.toFixed(1)+'%':d.bioMargin+'%'}</div>`:''}
        </div>
      </div>`;
  }).join('');
}

function filterDB(val) { 
  if (window.updateFilters) updateFilters(); 
}
window.filterDB = filterDB;

function exportToCSV() {
  const data = window._dbAll;
  if (!data) return showNotif("No hay datos para exportar");

  let csvContent = "data:text/csv;charset=utf-8,ID,Especie,Evaluador,Cliente,Fecha,Latitud,Longitud,Riesgo ISA,RoH QTRA,Margen APO,Ocupacion Diana,Valor Diana\n";

  Object.values(data).forEach(d => {
    const dt = new Date(d.timestamp).toLocaleDateString('es-ES');
    const lat = d.gps ? d.gps.lat : "";
    const lng = d.gps ? d.gps.lng : "";
    const isa = d.isaLevel || "";
    const qtra = d.qtraStr || "";
    const margen = d.bioMargin !== undefined && d.bioMargin !== null ? d.bioMargin : "";
    
    const cliente = d.cliente || (d.answers && d.answers.cliente) || "";
    const ocupacion = (d.answers && d.answers.tasaOcup) || "";
    const valor = (d.answers && d.answers.valorProp) || "";

    const row = `"${d.arbolId}","${d.especie}","${d.evaluador}","${cliente}","${dt}","${lat}","${lng}","${isa}","${qtra}","${margen}","${ocupacion}","${valor}"`;
    csvContent += row + "\n";
  });

  const encodedUri = encodeURI(csvContent);
  const link = document.createElement("a");
  link.setAttribute("href", encodedUri);
  link.setAttribute("download", "evaluaciones_arbolado.csv");
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
}
window.exportToCSV = exportToCSV;

function showTreeDetail(key) {
  const data = window._dbAll;
  if (!data || !data[key]) return;
  const d = data[key];
  const lvlCls = {bajo:'rb-low',moderado:'rb-mod',alto:'rb-high',extremo:'rb-ext'};
  const lvlLabel = {bajo:'BAJO',moderado:'MODERADO',alto:'ALTO',extremo:'EXTREMO'};
  const dt = new Date(d.timestamp).toLocaleString('es-ES',{day:'2-digit',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'});
  document.getElementById('modalTitle').textContent = `🌳 ${d.arbolId} · ${d.especie}`;
  const ans = d.answers || {};
  const fields = [
    ['Cliente',ans.cliente || d.cliente],['Evaluador',ans.evaluador || d.evaluador],['Especie',d.especie],
    ['Vigor',ans.vigor],['Exposición Viento',ans.exposViento],['Perfil Fallo',ans.perfilFallo],
    ['Prob. Fallo',ans.probFallo],['Consecuencias',ans.consec],
    ['Parte Fallo',ans.parteFallo],['Ø Parte Fallo',ans.diaFallo],
    ['Peatones/día',ans.peatones!=null?ans.peatones:null],['Vehículos/día',ans.vehiculos!=null?ans.vehiculos:null],
    ['Valor Propiedad (USD)', ans.valorProp!=null?ans.valorProp:null]
  ].filter(([,v]) => v !== undefined && v !== null && v !== '');

  document.getElementById('modalBody').innerHTML = `
    <div class="risk-banner ${lvlCls[d.isaLevel]||'rb-low'}">
      <div class="rb-level">${lvlLabel[d.isaLevel]||'—'}</div>
      <div class="rb-label">Riesgo ISA TRAQ</div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:12px">
      <div class="detail-item"><div class="di-label">QTRA RoH</div><div class="di-val" style="color:var(--b700)">${d.qtraStr||'—'}</div></div>
      <div class="detail-item"><div class="di-label">QTRA Estado</div><div class="di-val">${d.qtraStatus||'—'}</div></div>
      ${d.tReq?`<div class="detail-item"><div class="di-label">t_req Rinntech</div><div class="di-val">${typeof d.tReq==='number'?d.tReq.toFixed(2):d.tReq} cm</div></div>`:''}
      ${d.bioMargin!=null?`<div class="detail-item"><div class="di-label">Margen Estructural</div><div class="di-val" style="color:${d.bioCritical?'var(--r700)':'var(--g800)'}">${typeof d.bioMargin==='number'?d.bioMargin.toFixed(1):d.bioMargin}%</div></div>`:''}
      ${d.bioCritical?'<div class="detail-item" style="grid-column:1/-1;background:var(--r100);border-color:var(--r400)"><div class="di-label" style="color:var(--r700)">⚠️ Alerta Biomecánica</div><div class="di-val" style="color:var(--r700)">CUELLO DE BOTELLA CRÍTICO</div></div>':''}
    </div>
    <div class="detail-section">
      <div class="detail-sec-title">Datos del Árbol</div>
      <div class="detail-grid">
        ${fields.map(([k,v])=>`<div class="detail-item"><div class="di-label">${k}</div><div class="di-val">${v}</div></div>`).join('')}
      </div>
    </div>
    ${d.gps?`
    <div class="detail-section">
      <div class="detail-sec-title">Ubicación GPS</div>
      <div style="padding:9px;background:var(--g50);border:1px solid var(--g700);border-radius:8px;font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--g800)">
        📍 ${d.gps.lat.toFixed(6)}, ${d.gps.lng.toFixed(6)}
        <br><a href="https://maps.google.com/?q=${d.gps.lat},${d.gps.lng}" target="_blank" style="color:var(--b700);font-size:11px;font-weight:700">Abrir en Google Maps →</a>
      </div>
    </div>`:''}
    <div style="font-size:10px;color:var(--muted);text-align:center;padding-top:6px">Evaluado: ${dt}</div>
    
    <button onclick="deleteRecord('${key}')" style="margin-top:16px; width:100%; padding:12px; background:var(--r100); color:var(--r700); border:1.5px solid var(--r400); border-radius:8px; font-weight:700; font-family:'IBM Plex Sans',sans-serif; cursor:pointer;">🗑️ Eliminar Evaluación Permanente</button>
  `;
  document.getElementById('detailModal').classList.add('open');
}
window.showTreeDetail = showTreeDetail;

async function deleteRecord(key) {
  if (confirm("¿Estás seguro de que deseas eliminar esta evaluación de forma permanente?")) {
    try {
      if (!window._fbRemove) throw new Error("Base de datos no conectada");
      
      // Actualización optimista: Borramos visualmente de inmediato para no esperar el lag de red
      if (window._dbAll && window._dbAll[key]) {
          delete window._dbAll[key];
      }
      if (window.updateFilters) window.updateFilters();
      closeModal();
      
      // Eliminamos el dato real en Firebase en segundo plano
      await window._fbRemove(key);
      showNotif("🗑️ Registro eliminado");
      
    } catch(e) {
      console.error("Error al eliminar:", e);
      showNotif("❌ Error al eliminar: " + e.message);
    }
  }
}
window.deleteRecord = deleteRecord;

function closeModal() {
  document.getElementById('detailModal').classList.remove('open');
}
window.closeModal = closeModal;

// ─── TAB SWITCHING ────────────────────────────────────────
function switchTab(tab) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  
  const viewId = tab === 'db' ? 'viewDB' : 'view' + tab.charAt(0).toUpperCase() + tab.slice(1);
  const viewEl = document.getElementById(viewId);
  if (viewEl) viewEl.classList.add('active');
  
  const tabEl = document.getElementById('tab-' + tab);
  if (tabEl) tabEl.classList.add('active');

  if (tab === 'map') {
    setTimeout(() => { if (typeof initMap === 'function') initMap(); if (mapInstance) mapInstance.invalidateSize(); }, 100);
  }
}
window.switchTab = switchTab;

// ─── NOTIFICATIONS ────────────────────────────────────────
function showNotif(msg) {
  const n = document.getElementById('notif');
  if (!n) return;
  n.textContent = msg;
  n.classList.add('show');
  setTimeout(() => n.classList.remove('show'), 3500);
}
window.showNotif = showNotif;

// ─── RESET ────────────────────────────────────────────────
function resetForm() {
  answers = {};
  gpsCoords = null;
  _multiSel = {};
  assessmentDone = false;
  buildForm();
  switchTab('form');
  const scrollEl = document.getElementById('formScroll');
  if (scrollEl) scrollEl.scrollTop = 0;
}
window.resetForm = resetForm;

// Expose all handlers
window.submitChoice  = submitChoice;
window.submitMulti   = submitMulti;
window.submitGroup   = submitGroup;
window.submitText    = submitText;
window.submitTextSkip= submitTextSkip;
window.submitNumber  = submitNumber;
window.editQuestion  = editQuestion;
window.toggleMulti   = toggleMulti;

// ─── INIT ─────────────────────────────────────────────────
buildForm();
computeAll();
</script>
</body>
</html>
